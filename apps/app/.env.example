# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/zimpletools?schema=public"

# NextAuth
AUTH_SECRET="your-secret-here"   # openssl rand -base64 32
AUTH_URL="https://app.zimple.tools"

# ─── CRON endpoints ─────────────────────────────────────────────────────────────
# Secreto compartido para disparar los endpoints de tareas programadas
# (/api/turnos-cron, /api/socios-cron, /api/storage-cron).
# Debe coincidir con el query param ?secret=... en el cron command de railway.json.
CRON_SECRET="change-me-please"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Mercado Pago ──────────────────────────────────────────────────────────────
# Obtené tus credenciales en: https://www.mercadopago.com.ar/developers/panel
#
# 1. MERCADOPAGO_ACCESS_TOKEN  → "Credenciales de producción" > Access Token
# 2. MERCADOPAGO_PUBLIC_KEY    → "Credenciales de producción" > Public Key
# 3. MP_WEBHOOK_SECRET         → Configuración > Webhooks > Clave secreta
# 4. MP_PLAN_MONTHLY_ID        → ID del plan mensual (crear en el dashboard de MP)
# 5. MP_PLAN_ANNUAL_ID         → ID del plan anual  (crear en el dashboard de MP)
#
# IMPORTANTE: Usar credenciales de PRODUCCIÓN para cobros reales.
# Para testing usar las de SANDBOX (prefijo TEST-).

MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MP_WEBHOOK_SECRET=""
MP_PLAN_MONTHLY_ID=""
MP_PLAN_ANNUAL_ID=""
