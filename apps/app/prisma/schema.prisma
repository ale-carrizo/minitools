// NextAuth v5 + Prisma adapter schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELED
  SUSPENDED
  EXPIRED
}

enum SubscriptionPlan {
  MONTHLY
  ANNUAL
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  suspended     Boolean   @default(false)
  suspendedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  subscription Subscription?
  toolUsage    ToolUsage[]
  cajaDias     CajaDia[]
  cajaCobros   CajaCobro[]
  productos    Producto[]
  movimientos  MovimientoStock[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 SubscriptionPlan
  status               SubscriptionStatus @default(TRIAL)
  startDate            DateTime           @default(now())
  endDate              DateTime?
  trialEndsAt          DateTime?
  priceMonthly         Float
  currency             String             @default("ARS")
  mpPreapprovalId      String?            // Mercado Pago preapproval ID
  mpPayerEmail         String?            // Payer email en MP
  mpPlanId             String?            // MP preapproval_plan ID usado
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]
}

model Invoice {
  id             String    @id @default(cuid())
  subscriptionId String
  amount         Float
  currency       String    @default("USD")
  status         String    // paid, pending, failed
  dueDate        DateTime
  paidAt         DateTime?
  description    String?
  createdAt      DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model ToolUsage {
  id         String   @id @default(cuid())
  userId     String
  toolSlug   String
  lastUsed   DateTime @default(now())
  usageCount Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolSlug])
}

// ── Control de Stock ─────────────────────────────────────────────────────────

model Producto {
  id          String   @id @default(cuid())
  userId      String
  nombre      String
  sku         String?
  categoria   String?
  descripcion String?
  precioCosto Float    @default(0)
  precioVenta Float    @default(0)
  stock       Int      @default(0)
  stockMinimo Int      @default(0)
  unidad      String   @default("unidad")
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  movimientos MovimientoStock[]
}

model MovimientoStock {
  id         String   @id @default(cuid())
  userId     String
  productoId String
  tipo       String   // entrada | salida | ajuste
  cantidad   Int
  stockAntes Int
  motivo     String?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
}

// ── Control de Caja ───────────────────────────────────────────────────────────

model CajaDia {
  id          String      @id @default(cuid())
  userId      String
  fecha       String      // YYYY-MM-DD
  cerrada     Boolean     @default(false)
  cerradaAt   DateTime?
  notaCierre  String?
  totalCache  Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cobros CajaCobro[]

  @@unique([userId, fecha])
}

model CajaCobro {
  id             String    @id @default(cuid())
  userId         String
  diaId          String
  monto          Float
  fechaCobro     String    // YYYY-MM-DD
  horaCobro      String?   // HH:MM
  medio          String    // transferencia | efectivo | mercadopago | tarjeta_debito | tarjeta_credito | otro
  source         String    // comprobante_ia | extracto | mercadopago | manual
  concepto       String?
  emisorNombre   String?
  emisorBanco    String?
  referencia     String?
  comprobanteUrl String?
  iaRaw          Json?
  iaConfidence   Float?
  iaProvider     String?
  iaModel        String?
  mpPaymentId    String?   @unique
  mpStatus       String?
  extractoRow    Json?
  anulado        Boolean   @default(false)
  anuladoAt      DateTime?
  anuladoMotivo  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dia  CajaDia @relation(fields: [diaId], references: [id], onDelete: Cascade)
}
