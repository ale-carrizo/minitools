// NextAuth v5 + Prisma adapter schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELED
  SUSPENDED
  EXPIRED
}

enum SubscriptionPlan {
  MONTHLY
  ANNUAL
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  suspended     Boolean   @default(false)
  suspendedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  subscription Subscription?
  toolUsage    ToolUsage[]
  cajaDias     CajaDia[]
  cajaCobros   CajaCobro[]
  productos    Producto[]
  movimientos  MovimientoStock[]
  clientes     Cliente[]
  presupuestos Presupuesto[]
  presupuestoTemplate PresupuestoTemplate?
  empleados    Empleado[]
  asistencias  RegistroAsistencia[]
  reciboConfig ReciboConfig?
  recibos      Recibo[]
  garantias    GarantiaProducto[]
  reclamos     ReclamoGarantia[]
  turnoConfig  TurnoConfig?
  turnoServicios TurnoServicio[]
  turnos       Turno[]
  liquidaciones Liquidacion[]
  liquidacionItems LiquidacionItem[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  plan                 SubscriptionPlan
  status               SubscriptionStatus @default(TRIAL)
  startDate            DateTime           @default(now())
  endDate              DateTime?
  trialEndsAt          DateTime?
  priceMonthly         Float
  currency             String             @default("ARS")
  mpPreapprovalId      String?            // Mercado Pago preapproval ID
  mpPayerEmail         String?            // Payer email en MP
  mpPlanId             String?            // MP preapproval_plan ID usado
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]
}

model Invoice {
  id             String    @id @default(cuid())
  subscriptionId String
  amount         Float
  currency       String    @default("USD")
  status         String    // paid, pending, failed
  dueDate        DateTime
  paidAt         DateTime?
  description    String?
  createdAt      DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model ToolUsage {
  id         String   @id @default(cuid())
  userId     String
  toolSlug   String
  lastUsed   DateTime @default(now())
  usageCount Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolSlug])
}

// ── Control de Stock ─────────────────────────────────────────────────────────

model Producto {
  id          String   @id @default(cuid())
  userId      String
  nombre      String
  sku         String?
  categoria   String?
  descripcion String?
  precioCosto Float    @default(0)
  precioVenta Float    @default(0)
  stock       Int      @default(0)
  stockMinimo Int      @default(0)
  unidad      String   @default("unidad")
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  movimientos MovimientoStock[]
}

model MovimientoStock {
  id         String   @id @default(cuid())
  userId     String
  productoId String
  tipo       String   // entrada | salida | ajuste
  cantidad   Int
  stockAntes Int
  motivo     String?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
}

// ── Control de Caja ───────────────────────────────────────────────────────────

model CajaDia {
  id          String      @id @default(cuid())
  userId      String
  fecha       String      // YYYY-MM-DD
  cerrada     Boolean     @default(false)
  cerradaAt   DateTime?
  notaCierre  String?
  totalCache  Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cobros CajaCobro[]

  @@unique([userId, fecha])
}

model CajaCobro {
  id             String    @id @default(cuid())
  userId         String
  diaId          String
  monto          Float
  fechaCobro     String    // YYYY-MM-DD
  horaCobro      String?   // HH:MM
  medio          String    // transferencia | efectivo | mercadopago | tarjeta_debito | tarjeta_credito | otro
  source         String    // comprobante_ia | extracto | mercadopago | manual
  concepto       String?
  emisorNombre   String?
  emisorBanco    String?
  referencia     String?
  comprobanteUrl String?
  iaRaw          Json?
  iaConfidence   Float?
  iaProvider     String?
  iaModel        String?
  mpPaymentId    String?   @unique
  mpStatus       String?
  extractoRow    Json?
  anulado        Boolean   @default(false)
  anuladoAt      DateTime?
  anuladoMotivo  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dia  CajaDia @relation(fields: [diaId], references: [id], onDelete: Cascade)
}

// ── Generador de Presupuestos ─────────────────────────────────────────────────

model Cliente {
  id        String   @id @default(cuid())
  userId    String
  nombre    String
  empresa   String?
  email     String?
  telefono  String?
  direccion String?
  cuit      String?
  notas     String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  presupuestos Presupuesto[]
}

model Presupuesto {
  id           String    @id @default(cuid())
  userId       String
  clienteId    String?
  numero       Int
  titulo       String
  estado       String    @default("borrador")
  fechaEmision String
  fechaVence   String?
  moneda       String    @default("ARS")
  descuento    Float     @default(0)
  iva          Float     @default(21)
  notas        String?
  notasCliente String?
  subtotal     Float     @default(0)
  totalFinal   Float     @default(0)
  logoUrl      String?
  pdfUrl       String?
  enviadoAt    DateTime?
  aceptadoAt   DateTime?
  rechazadoAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  cliente Cliente?          @relation(fields: [clienteId], references: [id])
  items   PresupuestoItem[]

  @@unique([userId, numero])
}

model PresupuestoTemplate {
  id                   String   @id @default(cuid())
  userId               String   @unique
  nombreComercial      String?
  razonSocial          String?
  cuit                 String?
  telefono             String?
  email                String?
  direccion            String?
  logoUrl              String?
  colorPrimario        String   @default("#5448EE")
  mostrarIvaDefault    Boolean  @default(true)
  diasValidezDefault   Int      @default(7)
  textoEncabezado      String?
  condicionesDefault   String?
  notasClienteDefault  String?
  serviciosFrecuentes  Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PresupuestoItem {
  id             String  @id @default(cuid())
  presupuestoId  String
  orden          Int
  descripcion    String
  cantidad       Float   @default(1)
  precioUnitario Float   @default(0)
  subtotal       Float   @default(0)

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
}

// ── Control de Asistencia ─────────────────────────────────────────────────────

model Empleado {
  id          String   @id @default(cuid())
  userId      String
  nombre      String
  apellido    String?
  cuil        String?
  cargo       String?
  salarioBasico Float?
  categoriaLaboral String?
  turnoInicio String?
  turnoFin    String?
  tolerancia  Int      @default(15)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  asistencias RegistroAsistencia[]
  liquidacionItems LiquidacionItem[]
}

model RegistroAsistencia {
  id              String   @id @default(cuid())
  userId          String
  empleadoId      String
  fecha           String
  horaEntrada     String?
  horaSalida      String?
  horasTrabajadas Float?
  estado          String   @default("presente")
  notas           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  empleado Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  @@unique([empleadoId, fecha])
}

// ── Recibo de Sueldo ──────────────────────────────────────────────────────────

model ReciboConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  razonSocial String
  cuit        String
  domicilio   String?
  localidad   String?
  actividad   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recibo {
  id               String   @id @default(cuid())
  userId           String
  empleadoId       String?
  empNombre        String
  empCuil          String?
  empCargo         String?
  empFechaIngreso  String?
  empModalidad     String
  periodo          String
  fechaPago        String
  conceptos        Json
  totalHaberes     Float    @default(0)
  totalDeducciones Float    @default(0)
  netoAPagar       Float    @default(0)
  nroFactura       String?
  estado           String   @default("borrador")
  notas            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Seguimiento de Garantías ──────────────────────────────────────────────────

model GarantiaProducto {
  id               String   @id @default(cuid())
  userId           String
  nombre           String
  marca            String?
  modelo           String?
  nroSerie         String?
  categoria        String?
  proveedor        String?
  nroFactura       String?
  fechaCompra      String?
  fechaVencimiento String?
  mesesGarantia    Int?
  precioCompra     Float?
  notas            String?
  activo           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reclamos ReclamoGarantia[]
}

model ReclamoGarantia {
  id          String   @id @default(cuid())
  userId      String
  productoId  String
  fecha       String
  estado      String   @default("abierto")
  descripcion String
  resolucion  String?
  notas       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  producto GarantiaProducto @relation(fields: [productoId], references: [id], onDelete: Cascade)
}

// ── Gestión de Turnos ─────────────────────────────────────────────────────────

model TurnoConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  horaInicio  String   @default("08:00")
  horaFin     String   @default("20:00")
  intervalo   Int      @default(30)
  diasHabiles String   @default("[1,2,3,4,5]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TurnoServicio {
  id        String   @id @default(cuid())
  userId    String
  nombre    String
  duracion  Int
  precio    Float    @default(0)
  color     String   @default("#5448EE")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  turnos Turno[]
}

model Turno {
  id            String   @id @default(cuid())
  userId        String
  servicioId    String?
  clienteNombre String
  clienteTel    String?
  clienteEmail  String?
  fecha         String
  horaInicio    String
  horaFin       String
  duracion      Int
  precio        Float    @default(0)
  estado        String   @default("pendiente")
  notas         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  servicio TurnoServicio? @relation(fields: [servicioId], references: [id], onDelete: SetNull)
}

// ── Liquidación de Sueldos ────────────────────────────────────────────────────

model Liquidacion {
  id        String   @id @default(cuid())
  userId    String
  periodo   String
  estado    String   @default("borrador")
  notas     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items LiquidacionItem[]

  @@unique([userId, periodo])
}

model LiquidacionItem {
  id               String   @id @default(cuid())
  userId           String
  liquidacionId    String
  empleadoId       String?
  empleadoNombre   String
  empleadoCuil     String?
  categoria        String?
  salarioBruto     Float
  diasTrabajados   Int      @default(30)
  diasHabiles      Int      @default(30)
  salarioCalculado Float
  horasExtraMonto  Float    @default(0)
  adicionalesMonto Float    @default(0)
  totalBruto       Float
  jubilacionEmpl   Float
  obraSocialEmpl   Float
  pamiEmpl         Float
  otrasDeduccs     Float    @default(0)
  totalDeduccs     Float
  netoAPagar       Float
  jubilacionEmp    Float
  fne              Float
  obraSocialEmp    Float
  artMonto         Float    @default(0)
  totalContribEmp  Float
  costoTotalEmp    Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  liquidacion Liquidacion  @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  empleado    Empleado?    @relation(fields: [empleadoId], references: [id], onDelete: SetNull)
}
